generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id
  email     String   @unique
  role      String
  name      String
  createdAt DateTime @map("created_at")

  @@map("users")
}

model InvestorProfile {
  id          String   @id
  userId      String   @map("user_id")
  name        String
  preferences Json
  portfolio   String[]
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@map("investor_profiles")
}

model OperatorProfile {
  id                 String   @id
  userId             String   @map("user_id")
  name               String
  phone              String
  whatsappNumber     String?  @map("whatsapp_number")
  region             String
  farmIds            String[] @map("farm_ids")
  verificationStatus String   @map("verification_status")
  createdAt          DateTime @map("created_at")

  @@map("operator_profiles")
}

model FarmProfile {
  id                  String   @id
  operatorId          String   @map("operator_id")
  name                String
  country             String
  region              String
  governorate         String
  latitude            Float?
  longitude           Float?
  areaHectares        Float    @map("area_hectares")
  soilType            String   @map("soil_type")
  waterSource         String   @map("water_source")
  currentCrop         String   @map("current_crop")
  plannedCrops        String[] @map("planned_crops")
  requestedCapitalUsd Float    @map("requested_capital_usd")
  projectedRoiPercent Float    @map("projected_roi_percent")
  cropCycleDays       Int      @map("crop_cycle_days")
  yieldHistory        Json     @map("yield_history")
  certifications      String[]
  documentUrls        String[] @map("document_urls")
  imageUrls           String[] @map("image_urls")
  status              String
  aiProfileSummary    String?  @map("ai_profile_summary")
  createdAt           DateTime @map("created_at")
  updatedAt           DateTime @map("updated_at")

  @@index([status])
  @@index([operatorId])
  @@map("farm_profiles")
}

model MatchResult {
  id                  String   @id
  farmId              String   @map("farm_id")
  investorId          String   @map("investor_id")
  score               Float
  confidence          String
  reasons             Json
  riskFlags           Json     @map("risk_flags")
  horizonFitMonths    Int      @map("horizon_fit_months")
  estimatedRoiPercent Float    @map("estimated_roi_percent")
  createdAt           DateTime @map("created_at")

  @@unique([farmId, investorId])
  @@index([investorId])
  @@map("match_results")
}

model DealRecommendation {
  id                       String   @id
  farmId                   String   @map("farm_id")
  investorId               String   @map("investor_id")
  structureType            String   @map("structure_type")
  recommendedInvestmentUsd Float    @map("recommended_investment_usd")
  projectedRoiPercent      Float    @map("projected_roi_percent")
  durationMonths           Int      @map("duration_months")
  terms                    Json
  rationale                String
  riskSummary              String   @map("risk_summary")
  aiConfidence             String   @map("ai_confidence")
  createdAt                DateTime @map("created_at")

  @@index([farmId])
  @@index([investorId])
  @@map("deal_recommendations")
}

model NotificationSignal {
  id                  String   @id
  alertType           String   @map("alert_type")
  severity            String
  title               String
  summary             String
  affectedFarmIds     String[] @map("affected_farm_ids")
  affectedInvestorIds String[] @map("affected_investor_ids")
  reasoning           String
  sourceUrl           String?  @map("source_url")
  actionRequired      Boolean  @map("action_required")
  createdAt           DateTime @map("created_at")

  @@index([severity])
  @@map("notification_signals")
}

model OperatorReport {
  id          String   @id
  farmId      String   @map("farm_id")
  operatorId  String   @map("operator_id")
  reportType  String   @map("report_type")
  period      String
  content     Json
  notes       String
  submittedAt DateTime @map("submitted_at")

  @@index([farmId])
  @@index([operatorId])
  @@map("operator_reports")
}

model AdminReviewItem {
  id          String   @id
  itemType    String   @map("item_type")
  targetId    String   @map("target_id")
  status      String
  aiSummary   String   @map("ai_summary")
  flags       Json
  reviewedBy  String?  @map("reviewed_by")
  reviewNote  String?  @map("review_note")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  @@index([status])
  @@index([itemType])
  @@map("admin_review_items")
}

model AuditLogEntry {
  id         String   @id
  adminId    String   @map("admin_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  before     Json?
  after      Json?
  timestamp  DateTime

  @@index([adminId])
  @@index([targetType, targetId])
  @@map("audit_log_entries")
}
